[includeIf "gitdir:~/code/src/github.com/hashhar/"]
    path = identity-personal
[includeIf "gitdir:~/code/src/github.com/trinodb/"]
    path = identity-starburst
[includeIf "gitdir:~/code/src/github.com/starburstdata/"]
    path = identity-starburst
[user]
	name = Ashhar Hasan
	# Require setting user.name and email per-repo
	useConfigOnly = true
	signingkey = 4CD0188E0E5784EF
[core]
	safecrlf = warn
	autocrlf = input
	editor = nvim
[commit]
	template = ~/.config/git/commit-template
	verbose = true
	# Enable this on a per-repo basis using `git config commit.gpgsign true`
	#gpgsign = true
[diff]
	renames = copies
	submodule = log
	algorithm = histogram
	wsErrorHighlight = old,new,context
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[fetch]
	recurseSubmodules = on-demand
	prune = true
[pull]
	ff = only
[format]
	attach = true
	from = true
	coverLetter = auto
[grep]
	lineNumber = true
[mailinfo]
	scissors = true
[merge]
	branchdesc = true
	log = true
	tool = vscode
	renameLimit = 0
[mergetool "vscode"]
	cmd = code --wait $MERGED
[pack]
	threads = 0
[push]
	default = simple
	recurseSubmodules = check
[rebase]
	missingCommitsCheck = warn
[status]
	submoduleSummary = true
[alias]
	grog = log --graph --abbrev-commit --decorate --all --format=format:\"%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(dim white) - %an%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n %C(white)%s%C(reset)\"
	s = status -s

	# Show the diff between the latest commit and the current state
	d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

	# Remove the old tag with this name and tag the latest commit with it.
	retag = "!r() { git tag -d $1 && git push origin :refs/tags/$1 && git tag $1; }; r"
[gpg]
	program = gpg
[log]
	follow = true
